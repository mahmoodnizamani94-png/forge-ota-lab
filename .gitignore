# Forge OTA Lab — .gitignore

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Android
local.properties
*.apk
*.aar
*.ap_
*.aab
.cxx/

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.fleet/
*.swp
*.swo
*~

# Kotlin
*.class

# Rust
target/
core-extractor-rs/target/
core-extractor-rs/crates/*/target/
core-extractor-rs/forge-jni/target/

# JNI built shared libraries (built from Rust, not checked in)
**/src/main/jniLibs/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Environment
*.env
.env.local

# Signing — NEVER commit keystores or Firebase config
*.jks
*.keystore
google-services.json

# Crash logs
hs_err_pid*

# Agent/AI development files — local only, not for public repo
.agents/
prd/
AGENTS.md
docs/status/
