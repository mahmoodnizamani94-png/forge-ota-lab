<?xml version="1.0" encoding="utf-8"?>
<!--
    Google Fonts provider certificates for downloadable fonts.
    Required by androidx.compose.ui:ui-text-google-fonts.

    These are the SHA-256 certificate hashes for the Google Mobile Services
    fonts provider (com.google.android.gms). Two sets: dev and prod.

    Source: https://developer.android.com/develop/ui/compose/text/fonts#downloadable-fonts
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>

    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>

    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
